# Copy this file to .env and adjust as needed.

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# --- Dashboard ---
DASHBOARD_PORT=8501

# --- MLflow ---
MLFLOW_TRACKING_URI=sqlite:///mlflow/mlflow.db

# --- Model defaults ---
DEFAULT_MODEL=XGBoost
DEFAULT_TEST_SIZE=90

# --- Caching (optional, used if you wire in Redis) ---
REDIS_URL=redis://redis:6379/0
ENABLE_CACHE=false
